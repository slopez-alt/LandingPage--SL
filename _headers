# Cache largo para assets estáticos (1 año)
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

/assets/logo.png
  Cache-Control: public, max-age=31536000, immutable

/assets/logo.webp
  Cache-Control: public, max-age=31536000, immutable

/assets/favicon-v2.png
  Cache-Control: public, max-age=31536000, immutable

/assets/favicon-sl.svg
  Cache-Control: public, max-age=31536000, immutable

# Cache corto para HTML (1 hora — se actualiza con cada deploy)
/*.html
  Cache-Control: public, max-age=3600

/*/index.html
  Cache-Control: public, max-age=3600

# Sin caché para sitemap y robots
/sitemap.xml
  Cache-Control: no-cache

/robots.txt
  Cache-Control: no-cache
